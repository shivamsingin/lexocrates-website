# Lexocrates Blog Backend - Environment Configuration
# Copy this file to .env and update the values

# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=lexocrates_blog
DB_PORT=3306

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Admin Default Credentials
ADMIN_EMAIL=admin@lexocrates.com
ADMIN_PASSWORD=admin123

# Cloudflare Workers Configuration (if using Cloudflare)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Shared Hosting Configuration (if using shared hosting)
SHARED_HOSTING_URL=https://yourdomain.com/api

# SEO Configuration
SEO_TITLE_MAX_LENGTH=60
SEO_DESCRIPTION_MAX_LENGTH=160
SEO_KEYWORD_DENSITY_MIN=0.5
SEO_KEYWORD_DENSITY_MAX=2.5
SEO_WORD_COUNT_MIN=300
SEO_WORD_COUNT_MAX=2500

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Security Configuration
BCRYPT_ROUNDS=10
SESSION_SECRET=your-session-secret-here

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@lexocrates.com
